{
    "version": 2,
    "builds": [
        {
            "src": "librarymanagement/wsgi.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "15mb",
                "runtime": "python3.9"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "librarymanagement/wsgi.py"
        }
    ]
}