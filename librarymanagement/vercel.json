{
    "builds": [
        {
            "src": "librarymanagement/wsgi.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "15mb",
                "runtime": "python3.9"
            }
        }
    ],
    "routes": [
        {
            "src": "/static/css/(.*)",
            "dest": "/static/css/$1"
        },
        {
            "src": "/static/js/(.*)",
            "dest": "/static/js/$1"
        },
        {
            "src": "/static/images/(.*)",
            "dest": "/static/images/$1"
        },
        {
            "src": "/(.*)",
            "dest": "librarymanagement/wsgi.py"
        }
    ]
}